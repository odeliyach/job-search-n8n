# ─────────────────────────────────────────────
# CareerOS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# GitHub Personal Access Token
# Required scopes: repo (read + write to job-search-data private repo)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Groq API Key
# Free tier at: https://console.groq.com
# Used in all LLM calls — model: llama-3.1-8b-instant
GROQ_API_KEY=gsk_your_groq_api_key_here

# n8n Encryption Key
# Used to encrypt credentials stored in n8n
# Generate with: openssl rand -hex 32
# WARNING: changing this key will invalidate all saved credentials
N8N_ENCRYPTION_KEY=your_32_byte_hex_key_here

# n8n Instance
# Port 5679 maps to internal 5678 (set in docker-compose.yml)
N8N_PORT=5679
